# Arbitrage bot — copy to fiat-rails/.env or arbitrage-bot/.env (NEVER commit .env)
PORT=4028
DRY_RUN=true

# Spread / position limits
MIN_SPREAD_BPS=25
MAX_POSITION_USD=50000
PROFIT_REINVEST_RATIO=0.5
WATCH_PAIRS=USD-IOU/EUR-IOU,USD-IOU/JPY-IOU,USD-IOU/GBP-IOU

# Upstream services
X402_GATEWAY_URL=http://127.0.0.1:4020
ORCHESTRATOR_URL=http://127.0.0.1:4022
COMPLIANCE_URL=http://127.0.0.1:4025

# Orderbook x402 (market-data path)
X402_ORDERBOOK_PATH=/x402/market-data/orderbook

# Optional: real issuer seed for live XRPL (orchestrator only — not used by bot)
# ISSUER_SEED=

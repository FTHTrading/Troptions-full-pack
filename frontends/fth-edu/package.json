{
  "name": "TroptionsEduAI",
  "version": "1.0.0",
  "description": "TROPTIONS EDU AI - Interactive Learning with Voice AI, Blockchain and AMM",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "submit:android": "eas submit --platform android",
    "submit:ios": "eas submit --platform ios"
  },
  "dependencies": {
    "@elevenlabs/react": "^1.6.2",
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-voice/voice": "^3.2.4",
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/stack": "^7.0.0",
    "@solana/web3.js": "^1.98.4",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.7.0",
    "ethers": "^6.16.0",
    "expo": "~52.0.0",
    "expo-av": "~14.0.0",
    "expo-local-authentication": "~14.0.0",
    "expo-notifications": "~0.29.0",
    "expo-secure-store": "~14.0.0",
    "expo-speech": "~12.0.0",
    "expo-status-bar": "~2.0.0",
    "expo-updates": "~0.26.0",
    "lottie-react-native": "^7.3.8",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.0",
    "react-native-chart-kit": "^6.12.2",
    "react-native-device-info": "^15.0.2",
    "react-native-gesture-handler": "~2.20.0",
    "react-native-gifted-chat": "^3.3.3",
    "react-native-markdown-display": "^7.0.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~3.16.0",
    "react-native-render-html": "^6.3.4",
    "react-native-safe-area-context": "~4.12.0",
    "react-native-screens": "~4.0.0",
    "react-native-share": "^12.3.1",
    "react-native-svg": "15.8.0",
    "react-native-typing-animation": "^0.1.7",
    "react-native-vector-icons": "^10.2.0",
    "react-native-web": "~0.19.0",
    "react-native-youtube-iframe": "^2.4.1",
    "xrpl": "^4.6.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.0",
    "typescript": "^5.6.0"
  },
  "private": true,
  "expo": {
    "name": "TROPTIONS EDU AI",
    "slug": "troptions-edu-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0f"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.troptions.eduai",
      "buildNumber": "1.0.0"
    },
    "android": {
      "package": "com.troptions.eduai",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0a0a0f"
      }
    },
    "plugins": [
      "expo-secure-store",
      "expo-local-authentication",
      "expo-notifications",
      "expo-av",
      "expo-speech"
    ]
  }
}

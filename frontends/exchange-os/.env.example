# Core deployment identity
NODE_ENV=production
TROPTIONS_DEPLOYMENT_ID=deploy-2026-04-25-001
TROPTIONS_RELEASE_CHANNEL=prod

# Control-plane deployment policy
TROPTIONS_CONTROL_PLANE_WRITES_ENABLED=0
TROPTIONS_ALLOW_NON_PROD_CHANNEL_WRITES=0
TROPTIONS_DEPLOYMENT_LOCKDOWN=0

# Auth and operator controls
TROPTIONS_ALLOW_STATIC_TOKEN_AUTH=0
# TROPTIONS_CONTROL_PLANE_TOKEN=replace-me-if-you-explicitly-enable-static-token-auth
TROPTIONS_OPERATOR_IP_ALLOWLIST=
TROPTIONS_ENFORCE_OPERATOR_SECURITY=1
TROPTIONS_SENSITIVE_ACTIONS=

# JWT keyset (preferred)
# TROPTIONS_JWT_KEYS_JSON={"activeKid":"jwt-k1","keys":[{"kid":"jwt-k1","secret":"replace-with-32-plus-char-secret","enabled":true}]}

# Legacy JWT fallback (not preferred)
# TROPTIONS_JWT_SECRET=replace-with-32-plus-char-secret

# Audit export signing keys (preferred)
# TROPTIONS_AUDIT_EXPORT_KEYS_JSON={"activeKid":"audit-k1","keys":[{"kid":"audit-k1","secret":"replace-with-32-plus-char-secret","enabled":true}]}

# Legacy audit fallback
# TROPTIONS_AUDIT_EXPORT_SECRET=replace-with-32-plus-char-secret
# TROPTIONS_AUDIT_EXPORT_KEY_ID=audit-k1

# Request controls
TROPTIONS_RATE_LIMIT_PER_MINUTE=120
TROPTIONS_RATE_LIMIT_WINDOW_SECONDS=60
TROPTIONS_IDEMPOTENCY_TTL_SECONDS=600

# Phase 9 data layer
TROPTIONS_DB_ADAPTER=sqlite
# DATABASE_URL=postgres://user:password@host:5432/troptions

# Phase 9 observability
TROPTIONS_BASE_URL=https://troptions.unykorn.org

# Voice narration
# DEEPGRAM_KEY=replace-with-deepgram-key
# DEEPGRAM_KEY_ALT=replace-with-backup-deepgram-key
# DEEPGRAM_KEY_FILE=C:\\Users\\your-user\\OneDrive - FTH Trading\\11-Downloads\\deepgram.txt

# ─────────────────────────────────────────────────
# TROPTIONS Exchange OS — src/app/exchange-os/
# ─────────────────────────────────────────────────

# XRPL network (testnet by default — set MAINNET vars to go live)
XRPL_NETWORK=testnet
XRPL_WEBSOCKET_URL=wss://s.altnet.rippletest.net:51233
XRPL_MAINNET_WS_URL=wss://xrplcluster.com
# Set to true to enable real mainnet transactions
XRPL_MAINNET_ENABLED=false

# TROPTIONS token config
TROPTIONS_XRPL_ISSUER=rJLMSTy77hTxqgDw9WMxCnYC8m5vhqN3FQ
TROPTIONS_XRPL_FEE_WALLET=rNX4faQ35SdtE4rDoEg8YeVLQKQ57AYyCt
# Optional: operator wallet addresses for reward routing
# TROPTIONS_TREASURY_WALLET=
# TROPTIONS_CREATOR_REWARD_WALLET=
# TROPTIONS_REFERRAL_WALLET=

# x402 Protocol (pay-per-use API gating)
# Set X402_ENABLED=true to require real payments for premium reports
X402_ENABLED=false
# X402_FACILITATOR_URL=https://your-x402-facilitator.example.com
# X402_RECEIVING_ADDRESS=your-base-wallet-address
X402_NETWORK=base
X402_ASSET=USDC

# CRM / Lead webhook (optional)
# TROPTIONS_CRM_WEBHOOK_URL=https://hooks.example.com/leads

# Exchange OS feature flags (override auto-detection)
# TROPTIONS_PRODUCTION_FEES=false

# Deepgram voice (already configured above — referenced by Exchange OS voice page too)
# DEEPGRAM_API_KEY=  ← alias for DEEPGRAM_KEY (either works)

# Solana Campaign Launcher (added 2026-05-15)
NEXT_PUBLIC_SOLANA_CLUSTER=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=
NEXT_PUBLIC_SOLANA_MAINNET_ENABLED=false
NEXT_PUBLIC_SOLANA_TREASURY_ADDRESS=
NEXT_PUBLIC_CAMPAIGN_BASE_URL=https://launch.unykorn.org

# Campaign persistence — Phase 2 (added 2026-05-15)
# SQLite path (relative to project root). Falls back to data/campaigns.json, then in-memory.
CAMPAIGN_DB_PATH=data/campaigns.db

# AI Assistant (added 2026-05-15)
# Set AI_ASSISTANT_ENABLED=true and configure a provider to enable live AI
AI_ASSISTANT_ENABLED=false
AI_GATEWAY_URL=
AI_PROVIDER=stub
# OPENAI_API_KEY=
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# UNYKORN_TEAM_API_URL=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=

# ─── Cloudflare D1 — Campaign persistence ───────────────────────────────────
# CAMPAIGN_DB binding is configured in wrangler.jsonc (d1_databases section).
# The store auto-detects D1 when the CF Workers binding is present.
# To provision:
#   wrangler d1 create troptions-campaigns
#   wrangler d1 execute troptions-campaigns --file=db/schema.sql
# Then paste the database_id returned by the first command into wrangler.jsonc.
# For Cloudflare Pages: set CAMPAIGN_DB in the Pages dashboard → Settings → Bindings.

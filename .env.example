# ── TROPTIONS Sovereign Stack ─────────────────────────────────────────────

# L1 node (JSON-RPC over HTTP)
L1_RPC_URL=http://127.0.0.1:9944
L1_PORT=9944
L1_DATA_DIR=./l1-data
L1_METRICS_PORT=9945
RUST_LOG=info

# API keys for protected write routes (comma-separated secrets)
API_KEYS=dev-key-change-me,ops-key-change-me
# DAO settlement gateway (comma-separated key_id:secret — secret also accepted as X-API-Key)
SETTLEMENT_API_KEYS=settlement:dev-settlement-secret
L1_PUBLIC_KEY=
DAO_PORT=8093

# Backend ports (PM2 / local)
DONK_PORT=8090
FTH_PORT=8091
TTN_PORT=8092

# DONK AI Tutor (port 8090 — Glass site Q&A points here; never put keys in browser JS)
OLLAMA_URL=http://localhost:11434
QDRANT_HOST=localhost
QDRANT_PORT=6333
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
WORKERS_AI_ENABLED=0
WORKERS_AI_MODEL=@cf/meta/llama-3.1-8b-instruct

# Cloudflare Workers AI (server-side only — use 3rd token from Desktop Workers AI txt = Workers API)
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_WORKERS_AI_TOKEN=
# Aliases also accepted by backends: WORKERS_AI_API_TOKEN, CLOUDFLARE_API_TOKEN

# DAO telecom / NEED AI (dao-service :8093)
TELNYX_API_KEY=
TELNYX_PUBLIC_KEY=
TELNYX_WEBHOOK_SECRET=
TELNYX_FROM_NUMBER=
TELECOM_DRY_RUN=true
NEEDAI_DISPATCH_URL=http://127.0.0.1:4020/v1/needai/dispatch

# Optional Workers AI proxy on dao-service (GET /ai/workers/status)
# WORKERS_AI_ENABLED=1

# FTH Academy / TTN
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
PINATA_JWT=
POLYGON_RPC=https://polygon-rpc.com
KENNY_CONTRACT=0x93F2a3266a81c1F3Ee2c196b90890A959bC69BD7
EVL_CONTRACT=
EVL_SALE_CONTRACT=
EVL_TREASURY=
BACKEND_WALLET=
BACKEND_KEY=
SOLANA_RPC=https://api.mainnet-beta.solana.com
IPFS_GATEWAY=https://gateway.pinata.cloud

# Optional — PolygonScan API (contract verification scripts only; never commit real keys)
# POLYGONSCAN_API_KEY=

# XRPL
XRPL_GATEWAY_ADDRESS=rPF2M1QjRj72rHdJyRqfFRTqWREBdJds3

# Docker services
POSTGRES_URL=postgresql://troptions:troptions@localhost:5432/troptions
REDIS_URL=redis://localhost:6379
